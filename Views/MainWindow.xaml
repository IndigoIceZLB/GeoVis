<!-- Views/MainWindow.xaml -->
<Window x:Class="GeoVis.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GeoVis.ViewModels"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1"
        FontFamily="Microsoft YaHei, Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <!-- 绑定 DataContext 到 MainViewModel -->
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧控制面板：固定宽度 260 -->
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧面板区域 -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="数据操作区" FontSize="18" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,16"/>

                <!-- 预留的导入按钮 -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="1. 数据建库 (CSV入表)" Foreground="#546E7A" Margin="0,0,0,5"/>

                    <!-- OD 数据行 -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="入库: OD 流向长表" Command="{Binding ImportMultiDataCommand}" CommandParameter="OD" Style="{StaticResource AcademicButtonStyle}"/>
                        <Button Grid.Column="1" Content="清空" Command="{Binding ClearTableCommand}" CommandParameter="OD" Margin="5,0,0,0" Background="#FFEBEE" Foreground="#C62828" BorderBrush="#FFCDD2" Style="{StaticResource AcademicButtonStyle}"/>
                    </Grid>

                    <!-- 降水数据行 -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="入库: 小时降水极简表" Command="{Binding ImportMultiDataCommand}" CommandParameter="Rainfall" Style="{StaticResource AcademicButtonStyle}"/>
                        <Button Grid.Column="1" Content="清空" Command="{Binding ClearTableCommand}" CommandParameter="Rainfall" Margin="5,0,0,0" Background="#FFEBEE" Foreground="#C62828" BorderBrush="#FFCDD2" Style="{StaticResource AcademicButtonStyle}"/>
                    </Grid>

                    <!-- 驻留数据行 -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="入库: 驻留信号密度表" Command="{Binding ImportMultiDataCommand}" CommandParameter="Mobility" Style="{StaticResource AcademicButtonStyle}"/>
                        <Button Grid.Column="1" Content="清空" Command="{Binding ClearTableCommand}" CommandParameter="Mobility" Margin="5,0,0,0" Background="#FFEBEE" Foreground="#C62828" BorderBrush="#FFCDD2" Style="{StaticResource AcademicButtonStyle}"/>
                    </Grid>

                    <!-- 人口数据行 -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="入库: 月度常住人口表" Command="{Binding ImportMultiDataCommand}" CommandParameter="Population" Style="{StaticResource AcademicButtonStyle}"/>
                        <Button Grid.Column="1" Content="清空" Command="{Binding ClearTableCommand}" CommandParameter="Population" Margin="5,0,0,0" Background="#FFEBEE" Foreground="#C62828" BorderBrush="#FFCDD2" Style="{StaticResource AcademicButtonStyle}"/>
                    </Grid>

                    <TextBlock Text="2. 空间底图交互" Foreground="#546E7A" Margin="0,15,0,5"/>
                    <Button Content="加载网格(GeoJSON)渲染" Command="{Binding LoadAndRenderMapCommand}" Margin="0,2" Style="{StaticResource AcademicButtonStyle}"/>
                    <!-- 新增时间切片控制台 -->
                    <Border Background="#F5F7FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="空间时间切片控制" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,10"/>
                            <TextBlock Text="空间渲染图层:" Foreground="#546E7A" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding MapModes}" 
                                      SelectedItem="{Binding SelectedMapMode}" 
                                      Margin="0,0,0,15" Background="White" Padding="5"/>
                            <!-- 1. OD 专属控制 -->
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMapMode}" Value="OD 流出与流入">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="OD 渲染指标:" Foreground="#546E7A" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding OdDisplayModes}" SelectedItem="{Binding SelectedOdDisplayMode}" Background="White"/>
                            </StackPanel>

                            <!-- 2. 做差专属控制 -->
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMapMode}" Value="驻留人口与变化 (做差)">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="做差对比基准:" Foreground="#546E7A" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding DiffModes}" SelectedItem="{Binding SelectedDiffMode}" Background="White" Margin="0,0,0,5"/>
                                <!-- 只有选特定日期才显示这个日期选择器 -->
                                <ComboBox ItemsSource="{Binding AvailableDates}" SelectedItem="{Binding ReferenceDate}" Background="#FFF3E0">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDiffMode}" Value="与选定日期同时间做差">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>
                            </StackPanel>

                            <!-- 3. 地图降水悬浮窗控制 -->
                            <StackPanel Margin="0,10,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMapMode}" Value="月度常住人口">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="地图微观气象观测:" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,5"/>
                                <CheckBox Content="右下角开启当小时降水柱状图" IsChecked="{Binding ShowMapRainfall}" Foreground="#1976D2" FontWeight="Bold" Margin="0,0,0,5"/>

                                <StackPanel Visibility="{Binding ShowMapRainfall, Converter={StaticResource BoolToVis}}">
                                    <!-- 【新增】一键全选复选框 -->
                                    <CheckBox Content="✅ 一键全选气象站" IsChecked="{Binding IsAllStationsSelected}" Foreground="#388E3C" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <ListBox ItemsSource="{Binding MapStations}" Height="120" BorderBrush="#E0E0E0" Background="White">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 【重点修复】：增加 UpdateSourceTrigger=PropertyChanged 确保立即响应 -->
                                                <CheckBox Content="{Binding StationId}" IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                          Command="{Binding DataContext.UpdateMapRainfallCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>
                            <!-- 日期选择下拉框 -->
                            <TextBlock Text="选择日期:" Foreground="#546E7A" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding AvailableDates}" 
                                      SelectedItem="{Binding SelectedDate}" 
                                      Margin="0,0,0,15"
                                      Background="White" Padding="5"/>

                            <!-- 小时滑块 -->
                            <TextBlock Text="{Binding SelectedHour, StringFormat='选择小时: {0:D2}:00'}" Foreground="#546E7A" Margin="0,0,0,5"/>
                            <Slider Minimum="0" Maximum="23" 
                                    Value="{Binding SelectedHour}" 
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Margin="0,0,0,5"/>

                            <!-- 刻度线说明 -->
                            <Grid>
                                <TextBlock Text="0" HorizontalAlignment="Left" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="12" HorizontalAlignment="Center" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="23" HorizontalAlignment="Right" FontSize="10" Foreground="Gray"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>

                <!-- 状态栏 -->
                <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="#78909C" FontSize="12"/>
            </Grid>
        </Border>

        <!-- 右侧可视化区域：分为两个选项卡 -->
        <TabControl Grid.Column="1" Background="#FFFFFF" BorderThickness="0" Margin="10" Padding="0">
            <!-- Tab 1: ScottPlot 时序图 -->
            <TabItem Header="📈 网络与气象时序统计" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F4F8" Padding="10" Margin="10,5,10,0">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,5,10,0" Background="#F0F4F8" >
                            <TextBlock Text="分析指标: " VerticalAlignment="Center" FontWeight="Bold" Foreground="#37474F"/>
                            <ComboBox Width="130" ItemsSource="{Binding ChartModes}" SelectedItem="{Binding SelectedChartMode}" Margin="5,0,20,0"/>

                            <TextBlock Text="叠加气象数据: " VerticalAlignment="Center" FontWeight="Bold" Foreground="#37474F"/>
                            <ComboBox Width="180" Margin="5,0,0,0" 
                                  ItemsSource="{Binding AvailableStations}" 
                                  SelectedItem="{Binding SelectedStation}"/>

                            <!-- 【新增】：锁定Y轴控件 -->
                            <CheckBox Content="🔒 锁定Y轴 (仅X轴滑动)" IsChecked="{Binding IsYAxisLocked}" 
                                      VerticalAlignment="Center" Margin="20,0,0,0" 
                                      FontWeight="Bold" Foreground="#D32F2F" 
                                      ToolTip="锁定所有指标的 Y 轴比例，方便左右拖拽查看全天数据"/>
                        </StackPanel>
                    </Border>

                    <ScottPlot:WpfPlot x:Name="MainChart" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: WebView2 空间地图 -->
            <TabItem Header="🗺️ 空间底图呈现" FontSize="14">
                <!-- 纯净的 WebView2，ECharts 会在其内部 DOM 渲染，绝不会发生遮挡问题！ -->
                <wv2:WebView2 x:Name="MapWebView" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>