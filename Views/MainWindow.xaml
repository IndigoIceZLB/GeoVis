<!-- Views/MainWindow.xaml -->
<Window x:Class="GeoVis.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GeoVis.ViewModels"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1"
        FontFamily="Microsoft YaHei, Segoe UI">

    <!-- 绑定 DataContext 到 MainViewModel -->
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧控制面板：固定宽度 260 -->
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧面板区域 -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="数据操作区" FontSize="18" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,16"/>

                <!-- 预留的导入按钮 -->
                <StackPanel Grid.Row="1">
                    <Button Content="导入空间数据 (DuckDB)" 
                            Margin="0,8" 
                            IsEnabled="False" 
                            Style="{StaticResource AcademicButtonStyle}"/>
                </StackPanel>

                <!-- 状态栏 -->
                <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="#78909C" FontSize="12"/>
            </Grid>
        </Border>

        <!-- 右侧可视化区域 -->
        <Grid Grid.Column="1" Background="#F8F9FA">
            <TextBlock Text="图表与地图渲染区 (等待加载...)" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Foreground="#B0BEC5" 
                       FontSize="24"/>
        </Grid>
    </Grid>
</Window>